# Dockerfile.web — сборка apps/web (Next.js 16) из монорепо OpenVitals
# Кладётся в корень репозитория, рядом с package.json

FROM node:20-slim AS base
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate
RUN apt-get update -y && apt-get install -y openssl && rm -rf /var/lib/apt/lists/*

# ---- deps: ставим зависимости всего монорепо ----
FROM base AS deps
WORKDIR /app
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json turbo.json ./
COPY apps/web/package.json apps/web/package.json
COPY packages packages
COPY services services
RUN pnpm install --frozen-lockfile

# ---- builder: собираем только apps/web через turbo filter по пути ----
FROM base AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/web/node_modules ./apps/web/node_modules
COPY . .
ENV NEXT_TELEMETRY_DISABLED=1
ENV NODE_ENV=production
# Сборка билд-тайм переменных не требует секретов — они читаются в рантайме
RUN pnpm exec turbo run build --filter=./apps/web

# ---- runner: минимальный рантайм-образ ----
FROM node:20-slim AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
RUN groupadd -r nodejs && useradd -r -g nodejs nextjs

# Next.js standalone output — требует output: 'standalone' в apps/web/next.config.*
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/public ./apps/web/public

# Директория для локально хранимых загруженных файлов (BLOB_STORAGE_PROVIDER=local)
RUN mkdir -p /app/apps/web/uploads && chown nextjs:nodejs /app/apps/web/uploads

USER nextjs
EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

CMD ["node", "apps/web/server.js"]
