# Dockerfile.web — сборка apps/web (Next.js 16) из монорепо OpenVitals
# Кладётся в корень репозитория, рядом с package.json

FROM node:20-slim AS base
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate
RUN apt-get update -y && apt-get install -y openssl && rm -rf /var/lib/apt/lists/*

# ---- builder: полный install монорепо + сборка apps/web ----
# Turbopack при сборке резолвит зависимости workspace-пакетов изнутри packages/*
# (drizzle-orm, pg, zod, @vercel/blob и т.д.), поэтому нужны node_modules ВСЕХ
# пакетов, а не только корневой и apps/web. Ставим зависимости на полном исходнике.
FROM base AS builder
WORKDIR /app
COPY . .
RUN pnpm install --frozen-lockfile
ENV NEXT_TELEMETRY_DISABLED=1
ENV NODE_ENV=production
# Сборка билд-тайм переменных не требует секретов — они читаются в рантайме.
# Заодно собираем ingestion-worker: из него берём самодостаточный dist/migrate.js
# для авто-применения миграций на старте web-контейнера.
RUN pnpm exec turbo run build --filter=./apps/web --filter=./services/ingestion-worker

# ---- runner: минимальный рантайм-образ ----
FROM node:20-slim AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
RUN groupadd -r nodejs && useradd -r -g nodejs nextjs

# Next.js standalone output — требует output: 'standalone' в apps/web/next.config.*
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/public ./apps/web/public

# Авто-миграции: самодостаточный бандл мигратора + SQL-файлы рядом с ним.
# Скрипт применяет только новые миграции (идемпотентно), затем стартует сервер.
COPY --from=builder --chown=nextjs:nodejs /app/services/ingestion-worker/dist/migrate.js ./apps/web/migrate.js
COPY --from=builder --chown=nextjs:nodejs /app/packages/database/drizzle ./apps/web/drizzle

# Директория для локально хранимых загруженных файлов (BLOB_STORAGE_PROVIDER=local)
RUN mkdir -p /app/apps/web/uploads && chown nextjs:nodejs /app/apps/web/uploads

USER nextjs
EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

# Сначала накатываем миграции, затем запускаем Next-сервер.
CMD ["sh", "-c", "node apps/web/migrate.js && node apps/web/server.js"]
